            else
                impatch MGOD2 B @type @jsum  PRIM @type @isum noautog
            endif
        endif
    endif
    if iy .eq. @Ny then
        if ix .eq. @Nx then
            calc jsum = @isum - @Nxy + 1
            coor stat sele segid @type .and. resid @jsum .and. type AL1 .or. -
                             segid @type .and. resid @jsum .and. type MG1 end
