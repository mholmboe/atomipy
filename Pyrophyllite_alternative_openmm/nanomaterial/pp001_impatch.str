if ix .eq. @Nx then
    if iy .eq. @Ny then
        if iz .eq. @Nz then
            impatch FKIMP PRIM @type @isum PRIM @type @jsum 
        endif
    endif
endif

if zpbc .eq. yes goto esccap
if pbc .eq. no goto esccap
label esccap
