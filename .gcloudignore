#!include:.gitignore

# Frontend build artifacts and config (not needed by backend services)
node_modules/
src/
public/
*.config.ts
*.config.js
tsconfig*.json
package.json
package-lock.json
components.json
index.html

# Dev/test files
tests/
scripts/
*.ipynb
playwright*.ts
vitest*.ts
run_integration_tests.py
test_app.py
restart_dev.sh

# Runtime artifacts
outputs/
dump.rdb
atomipy_system_bundle-*/

# Large data bundles not needed at build time
atomipy/structures/minerals/Hexagonal_pyro_mmt/
atomipy/structures/minerals/Hexagonal_talc_laponite/
