DispCorr                 	= EnerPres 
fourierspacing           	= 0.12 
fourier-nx               	= 0 
fourier-ny               	= 0 
fourier-nz               	= 0 
pme-order                	= 4 
ewald-rtol               	= 1e-05 
ewald-rtol-lj            	= 0.001 
lj-pme-comb-rule         	= Geometric 
ewald-geometry           	= 3d 
epsilon-surface          	= 0 
implicit-solvent         	= no 
tcoupl                   	= V-rescale 
nsttcouple               	= -1 
nh-chain-length          	= 10 
tc-grps                  	= System 
tau-t                    	= 2 
ref-t                    	= 298 
pcoupl                   	= no 
pcoupltype               	= Isotropic 
nstpcouple               	= -1 
tau-p                    	= 1 
compressibility          	= 4e-05 
