refcoord-scaling         	= com 
gen-vel                  	= no 
gen-temp                 	= 300 
gen-seed                 	= -1 
constraints              	= none 
constraint-algorithm     	= Lincs 
continuation             	= no 
Shake-SOR                	= no 
shake-tol                	= 0.0001 
lincs-order              	= 4 
