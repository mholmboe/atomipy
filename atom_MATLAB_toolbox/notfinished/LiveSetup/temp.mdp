simulation-part          	= 1 
comm-mode                	= Linear 
nstcomm                  	= 10 
comm-grps                	= System 
bd-fric                  	= 0 
ld-seed                  	= -1 
emtol                    	= 10 
emstep                   	= 0.01 
niter                    	= 20 
fcstep                   	= 0 
nstcgsteep               	= 1000 
nbfgscorr                	= 10 
rtpi                     	= 0.05 
nstxout                  	= 0 
nstvout                  	= 0 
nstfout                  	= 0 
nstlog                   	= 100 
nstcalcenergy            	= 100 
nstenergy                	= 100 
nstxout-compressed       	= 1000 
compressed-x-precision   	= 1000 
compressed-x-grps        	= System 
energygrps               	= System 
cutoff-scheme            	= Verlet 
nstlist                  	= 20 
pbc                      	= xyz 
periodic-molecules       	= yes 
verlet-buffer-tolerance  	= 0.005 
rlist                    	= 1 
coulombtype              	= PME 
coulomb-modifier         	= Potential-shift-Verlet 
rcoulomb-switch          	= 0 
rcoulomb                 	= 1 
epsilon-r                	= 1 
epsilon-rf               	= 0 
vdw-type                 	= Cut-off 
vdw-modifier             	= Potential-shift-Verlet 
rvdw-switch              	= 0 
